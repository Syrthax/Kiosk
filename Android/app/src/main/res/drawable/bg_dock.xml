<?xml version="1.0" encoding="utf-8"?>
<!--
  Glassmorphism dock background – theme-aware.
  Light mode: translucent light surface. Dark mode: translucent dark surface.
  True backdrop blur requires API 31+ RenderEffect; this simulates the
  frosted-glass aesthetic across all API levels with a translucent fill,
  a thin border-stroke, and a bottom shadow (set via elevation on the
  host view).
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <solid android:color="@color/dock_surface" />
    <corners android:radius="28dp" />
    <stroke
        android:width="0.75dp"
        android:color="@color/dock_border" />
</shape>
