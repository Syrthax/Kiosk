<?xml version="1.0" encoding="utf-8"?>
<!--
  Kiosk Home Screen
  ─────────────────
  • Header with logo + app name
  • Open PDF button
  • Recent PDFs section (populated in code)
  • About section
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="?android:colorBackground"
    tools:context=".ui.MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:clipToPadding="false">

        <!-- ═══════ Header ═══════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:layout_marginTop="64dp"
            android:layout_marginBottom="20dp">

            <ImageView
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:src="@mipmap/ic_launcher"
                android:contentDescription="@string/app_name"
                android:layout_marginBottom="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textSize="30sp"
                android:textStyle="bold"
                android:textColor="?colorOnBackground" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/welcome_message"
                android:textSize="14sp"
                android:textColor="?colorOnSurface"
                android:alpha="0.6"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- ═══════ Open PDF Button ═══════ -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/openButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginHorizontal="32dp"
            android:layout_marginBottom="28dp"
            android:text="@string/open_pdf"
            android:textSize="16sp"
            app:cornerRadius="28dp" />

        <!-- ═══════ Recent PDFs Section ═══════ -->
        <TextView
            android:id="@+id/recentTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/recent_files"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="?colorOnBackground"
            android:layout_marginBottom="8dp" />

        <!-- Entries are added programmatically -->
        <LinearLayout
            android:id="@+id/recentContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <TextView
            android:id="@+id/noRecentsLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/no_recent_files"
            android:textSize="14sp"
            android:textColor="?colorOnSurface"
            android:alpha="0.5"
            android:visibility="gone" />

        <!-- ═══════ Divider ═══════ -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?colorOnSurface"
            android:alpha="0.10"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="18dp" />

        <!-- ═══════ About Section ═══════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/about_heading"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="?colorOnBackground"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/aboutSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/about_text"
            android:textSize="13sp"
            android:textColor="?colorOnSurface"
            android:alpha="0.7"
            android:lineSpacingMultiplier="1.5"
            android:layout_marginBottom="48dp" />

    </LinearLayout>
</ScrollView>
